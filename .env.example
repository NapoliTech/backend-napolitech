# =============================================================
# Napolitech Backend — variáveis de ambiente
# Copie para .env e preencha antes de subir o docker-compose.
# NUNCA commite o .env com valores reais.
# =============================================================

# --------------------------------------------------------------
# Spring Boot
# --------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
SPRING_APPLICATION_NAME=back-end-napolitech

# --------------------------------------------------------------
# Servidor
# --------------------------------------------------------------
SERVER_PORT=8080
SERVER_ADDRESS=0.0.0.0

# --------------------------------------------------------------
# Banco de dados (MySQL)
# --------------------------------------------------------------
DATASOURCE_URL=jdbc:mysql://db:3306/pizzaria_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
DATASOURCE_USERNAME=napolitech
DATASOURCE_PASSWORD=napolitech_dev
DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver

# --------------------------------------------------------------
# JWT
# Mínimo 32 caracteres aleatórios. Fixe este valor para que
# tokens não sejam invalidados ao reiniciar o servidor.
# Gerador: openssl rand -hex 32
# --------------------------------------------------------------
JWT_SECRET=troque-por-uma-string-aleatoria-com-no-minimo-32-chars
JWT_EXPIRATION=86400000

# --------------------------------------------------------------
# CORS — origens permitidas separadas por vírgula
# Suporta wildcards: https://*.ngrok-free.app
# Atualize com a URL do ngrok a cada nova sessão, ex:
#   FRONTEND_ALLOWED_ORIGINS=https://abc123.ngrok-free.app,http://localhost:19006
# --------------------------------------------------------------
FRONTEND_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19000,http://localhost:19006,http://10.0.2.2:8081

# --------------------------------------------------------------
# Frontend — URL base usada em links de e-mail (reset de senha)
# Em produção, use o domínio real. Com ngrok, use a URL pública do front.
# --------------------------------------------------------------
FRONTEND_BASE_URL=http://localhost:5173

# --------------------------------------------------------------
# Email (Gmail SMTP)
# --------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-app-password-gmail
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# --------------------------------------------------------------
# RabbitMQ
# --------------------------------------------------------------
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=napolitech
BROKER_EXCHANGE_NAME=napolitech-exchange
BROKER_QUEUE_NAME=pedidos-queue
BROKER_ROUTING_KEY=pedidos-routing-key

# --------------------------------------------------------------
# Redis
# --------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --------------------------------------------------------------
# Ollama (IA de upsell — LLM local)
# Após subir os containers, baixe o modelo uma única vez:
#   docker exec ollama ollama pull llama3.2
# Para CPU mais rápido: docker exec ollama ollama pull llama3.2:1b
# --------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# --------------------------------------------------------------
# ngrok (necessário apenas com --profile ngrok)
# Obtenha o token em: https://dashboard.ngrok.com/get-started/your-authtoken
# --------------------------------------------------------------
NGROK_AUTHTOKEN=seu-authtoken-do-ngrok
